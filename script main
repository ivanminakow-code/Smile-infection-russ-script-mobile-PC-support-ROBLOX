-- ========== ФУНКЦИЯ ОПРЕДЕЛЕНИЯ АДМИНА ==========
local function isAdmin(player)
    if player.UserId == 1 then return true end
    if player.Name == "ROBLOX" then return true end
    if player:GetAttribute("Admin") == true then return true end
    pcall(function()
        if player.MembershipType == Enum.MembershipType.GameMaster then return true end
        if player:IsStaff() then return true end
    end)
    if player.Team and player.Team.Name:lower() == "admin" then return true end
    return false
end

