local function checkForAdmins()
    if not autoKickEnabled then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and isAdmin(player) then
            if not adminDetected then
                adminDetected = true
                showKickWarning(player.DisplayName or player.Name)
            end
            return true
        end
    end
    return false
end

spawn(function()
