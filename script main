                    hrp.Velocity = vel * flingPower + Vector3.new(0, flingPower, 0)
                    task.wait()
                    if char and char.Parent and hrp and hrp.Parent then
                        hrp.Velocity = vel
                    end
                    task.wait()
                    if char and char.Parent and hrp and hrp.Parent then
                        hrp.Velocity = vel + Vector3.new(0, 0.1, 0)
                    end
                end
            end)
        else
